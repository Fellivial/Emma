# Emma staging environment example.
# Copy to .env.staging and fill with staging-only values outside Git.
# Do not commit .env.staging or any real secret values.

# App / deployment
NEXT_PUBLIC_APP_URL=https://staging-emma.your-domain.invalid
NODE_ENV=production

# Supabase staging project
NEXT_PUBLIC_SUPABASE_URL=https://staging-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-supabase-service-role-key>

# AI providers
OPENROUTER_API_KEY=<staging-openrouter-api-key>
OPENAI_API_KEY=<staging-openai-api-key-for-stt>

# Encryption and application secrets
EMMA_ENCRYPTION_KEY=<64-hex-character-staging-key>
# Only during a key-rotation window (see docs/runbook-encryption-key-escrow.md):
# EMMA_ENCRYPTION_KEY_PREVIOUS=<retiring-64-hex-character-staging-key>
EMMA_UNSUBSCRIBE_SECRET=<staging-unsubscribe-hmac-secret>
CRON_SECRET=<staging-cron-secret>

# Rate limiting
UPSTASH_REDIS_REST_URL=https://staging-upstash-rest-url.invalid
UPSTASH_REDIS_REST_TOKEN=<staging-upstash-rest-token>

# Email
RESEND_API_KEY=<staging-resend-api-key>
EMAIL_FROM=Emma Staging <noreply@staging.your-domain.invalid>

# Admin / access
EMMA_ADMIN_EMAILS=founder-staging@your-domain.invalid,validator-staging@your-domain.invalid

# LemonSqueezy sandbox billing
LEMONSQUEEZY_API_KEY=<lemon-sandbox-api-key>
LEMONSQUEEZY_STORE_ID=<lemon-sandbox-store-id>
LEMONSQUEEZY_WEBHOOK_SECRET=<lemon-sandbox-webhook-secret>
NEXT_PUBLIC_LEMON_VARIANT_STARTER=<lemon-sandbox-starter-variant-id>
NEXT_PUBLIC_LEMON_VARIANT_PRO=<lemon-sandbox-pro-variant-id>
NEXT_PUBLIC_LEMON_VARIANT_EXTRA_PACK=<lemon-sandbox-extra-pack-variant-id>

# Inngest staging
INNGEST_SIGNING_KEY=<staging-inngest-signing-key>
INNGEST_EVENT_KEY=<staging-inngest-event-key>

# Sentry staging
SENTRY_DSN=https://staging-sentry-dsn.invalid/0
SENTRY_ORG=<staging-sentry-org>
SENTRY_PROJECT=<staging-sentry-project>
SENTRY_AUTH_TOKEN=<staging-sentry-auth-token>

# Web push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<staging-vapid-public-key>
VAPID_PRIVATE_KEY=<staging-vapid-private-key>

# Inbound ingest
INGEST_EMAIL_WEBHOOK_SECRET=<staging-email-ingest-secret>

# Optional integrations for staging validation
GOOGLE_CLIENT_ID=<staging-google-client-id>
GOOGLE_CLIENT_SECRET=<staging-google-client-secret>
NOTION_CLIENT_ID=<staging-notion-client-id>
NOTION_CLIENT_SECRET=<staging-notion-client-secret>
SLACK_CLIENT_ID=<staging-slack-client-id>
SLACK_CLIENT_SECRET=<staging-slack-client-secret>
HUBSPOT_API_KEY=<staging-hubspot-private-app-token>
HUBSPOT_CLIENT_ID=<staging-hubspot-client-id>
HUBSPOT_CLIENT_SECRET=<staging-hubspot-client-secret>

# Optional WhatsApp staging validation
WHATSAPP_ACCESS_TOKEN=<staging-whatsapp-access-token>
WHATSAPP_PHONE_NUMBER_ID=<staging-whatsapp-phone-number-id>
WHATSAPP_VERIFY_TOKEN=<staging-whatsapp-verify-token>
WHATSAPP_APP_SECRET=<staging-whatsapp-app-secret>
