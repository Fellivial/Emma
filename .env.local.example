# ─── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# ─── Optional ─────────────────────────────────────────────────────────────────

# ElevenLabs TTS — BYOK (no server key needed)
# Users connect their own key via Settings → Integrations
# See: src/app/api/integrations/elevenlabs/route.ts

# Email sequences (Resend)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=Emma <emma@yourdomain.com>
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Google OAuth (Gmail + Calendar integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twilio SMS + WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1555...
TWILIO_WHATSAPP_NUMBER=+1555...

# Extra Response Pack (LemonSqueezy variant ID for $9 pack)
LEMONSQUEEZY_VARIANT_EXTRA_PACK=

# LemonSqueezy billing
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ─── Error Monitoring (Sentry) ───────────────────────────────────────────────

# Get your DSN from: sentry.io → your project → Settings → Client Keys (DSN)
SENTRY_DSN=

# Required for source map uploads (enables readable stack traces in Sentry)
# Get from: sentry.io → your project → Settings → Auth Tokens
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Security (W13) ──────────────────────────────────────────────────────────

# Field-level encryption key (AES-256). Generate with: openssl rand -hex 32
EMMA_ENCRYPTION_KEY=

# Admin panel access (comma-separated emails)
EMMA_ADMIN_EMAILS=your@email.com

# Cron authentication (Vercel sets this automatically when CRON_SECRET env var is set)
# Generate with: openssl rand -hex 32
CRON_SECRET=
