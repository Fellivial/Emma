# ─── Required ─────────────────────────────────────────────────────────────────
# OpenRouter — replaces ANTHROPIC_API_KEY (get key at openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-xxxxx

# OpenAI — STT fallback only (OpenRouter doesn't expose audio endpoints)
# Starter plan uses gpt-4o-mini-transcribe; Pro/Enterprise use gpt-4o-transcribe
OPENAI_API_KEY=sk-xxxxx

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# ─── Optional ─────────────────────────────────────────────────────────────────

# ElevenLabs TTS — BYOK (no server key needed)
# Users connect their own key via Settings → Integrations
# See: src/app/api/integrations/elevenlabs/route.ts

# Email sequences (Resend)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=Emma <emma@yourdomain.com>
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Google OAuth (Gmail + Calendar integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WhatsApp Business Cloud API (Meta)
# Get from: developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Set this to any secret string — used to verify Meta webhook subscription
WHATSAPP_VERIFY_TOKEN=

# LemonSqueezy billing
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# LemonSqueezy variant IDs — find in Dashboard → Products → your plan → Variants
# NEXT_PUBLIC_ prefix required: billing page is a client component
NEXT_PUBLIC_LEMON_VARIANT_STARTER=
NEXT_PUBLIC_LEMON_VARIANT_PRO=
NEXT_PUBLIC_LEMON_VARIANT_EXTRA_PACK=

# HubSpot private app token (Portal Settings → Integrations → Private Apps)
HUBSPOT_API_KEY=

# Notion OAuth (api.notion.com → My Integrations → New integration → OAuth)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Slack OAuth v2 (api.slack.com → Your Apps → Create App → OAuth & Permissions)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ─── Error Monitoring (Sentry) ───────────────────────────────────────────────

# Get your DSN from: sentry.io → your project → Settings → Client Keys (DSN)
SENTRY_DSN=

# Required for source map uploads (enables readable stack traces in Sentry)
# Get from: sentry.io → your project → Settings → Auth Tokens
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Rate Limiting (Upstash Redis) ──────────────────────────────────────────

# Upstash Redis REST API — sliding-window rate limiting on brain route
# Get from: upstash.com → your database → REST API tab
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Web Push Notifications ──────────────────────────────────────────────────

# VAPID keys for Web Push API. Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Background Workers (Inngest) ────────────────────────────────────────────

# Durable cron execution with step-level retry and observability.
# Get from: app.inngest.com → your app → Manage → Signing Key + Event Key
# Leave blank to run on Vercel cron only (Inngest is opt-in).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Security (W13) ──────────────────────────────────────────────────────────

# Field-level encryption key (AES-256). Generate with: openssl rand -hex 32
EMMA_ENCRYPTION_KEY=

# Separate HMAC key for unsubscribe link tokens (decoupled so key rotation
# doesn't invalidate already-sent email unsubscribe links)
# Generate with: openssl rand -hex 32
EMMA_UNSUBSCRIBE_SECRET=

# Inbound email webhook auth secret (for /api/emma/ingest/email)
INGEST_EMAIL_WEBHOOK_SECRET=

# WhatsApp webhook signature validation (Meta app secret)
WHATSAPP_APP_SECRET=

# Admin panel access (comma-separated emails)
EMMA_ADMIN_EMAILS=your@email.com

# Cron authentication (Vercel sets this automatically when CRON_SECRET env var is set)
# Generate with: openssl rand -hex 32
CRON_SECRET=
