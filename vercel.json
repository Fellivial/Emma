{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["sin1"],
  "functions": {
    "src/app/api/emma/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/emma/vision/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/emma/summarize/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/emma/emotion/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/emma/memory/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/emma/tts/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/emma/agent/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/emma/webhook/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/emma/cron/email-sequences/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/emma/cron/scheduled-tasks/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/emma/cron/approvals-expiry/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/emma/cron/email-sequences",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/emma/cron/scheduled-tasks",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/emma/cron/approvals-expiry",
      "schedule": "*/5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/emma",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store" },
        { "key": "X-Accel-Buffering", "value": "no" }
      ]
    }
  ]
}
